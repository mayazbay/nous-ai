<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <key>Label</key>
    <string>com.nous.todoist-sync</string>

    <key>ProgramArguments</key>
    <array>
        <string>/opt/homebrew/bin/python3</string>
        <string>/Users/madia/nous-agaas/wiki/tools/todoist_sync.py</string>
        <string>--loop</string>
        <string>--owner</string>
        <string>air</string>
        <string>--env-file</string>
        <string>/Users/madia/nous-agaas/.env</string>
        <string>--interval</string>
        <string>300</string>
        <string>--lease-ttl</string>
        <string>90</string>
        <string>--lease-refresh-interval</string>
        <string>30</string>
